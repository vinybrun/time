# Copy to .env on the server. Never commit the real .env.
DATABASE_URL=sqlite:////srv/apps/time/data/time.db

# Generate with: python -c "import secrets;print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-64-char-hex-secret
ACCESS_TOKEN_TTL_HOURS=720

# Local Postfix relay (this box is the alterspring.org mail server)
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USE_TLS=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=Time <time@alterspring.org>

CODE_TTL_MINUTES=30

# Web origin allowed by CORS (the deployed app)
CORS_ORIGINS=https://time.sovereinia.org
APP_BASE_URL=https://time.sovereinia.org
